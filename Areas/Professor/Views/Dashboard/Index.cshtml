@{
    ViewData["Title"] = "Dashboard - Área do Professor";
}

<div class="main-content">
    <div class="dashboard-header">
        <h1>Bem-vindo, Professor!</h1>
        <p>Gerencie suas turmas e acompanhe o progresso dos alunos.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="card">
            <i class="fas fa-users text-4xl text-primary mb-4"></i>
            <h3 class="text-xl font-semibold mb-2">20</h3>
            <p class="text-gray-600">Alunos Matriculados</p>
        </div>
        <div class="card">
            <i class="fas fa-chalkboard-teacher text-4xl text-primary mb-4"></i>
            <h3 class="text-xl font-semibold mb-2">4</h3>
            <p class="text-gray-600">Turmas Ativas</p>
        </div>
        <div class="card">
            <i class="fas fa-book-open text-4xl text-primary mb-4"></i>
            <h3 class="text-xl font-semibold mb-2">12</h3>
            <p class="text-gray-600">Aulas Ministradas</p>
        </div>
        <div class="card">
            <i class="fas fa-calendar-check text-4xl text-primary mb-4"></i>
            <h3 class="text-xl font-semibold mb-2">85%</h3>
            <p class="text-gray-600">Presença Média</p>
        </div>
    </div>

    <div class="perfil-card">
        <h2 class="text-2xl font-bold mb-4">Suas Turmas</h2>
        <div class="space-y-4">
            <div class="border border-gray-200 rounded-lg p-4">
                <h3 class="font-semibold text-lg">Tecnologia da Informação - Manhã</h3>
                <p class="text-gray-600">Segunda-feira, Wednesday e Friday - 08:00 às 12:00</p>
                <p class="text-primary font-semibold mt-2">15 alunos matriculados</p>
            </div>
            <div class="border border-gray-200 rounded-lg p-4">
                <h3 class="font-semibold text-lg">Tecnologia da Informação - Tarde</h3>
                <p class="text-gray-600">Terça-feira, Thursday e Sexta - 14:00 às 18:00</p>
                <p class="text-primary font-semibold mt-2">5 alunos matriculados</p>
            </div>
        </div>
    </div>
</div>
